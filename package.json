{
  "name": "@getforma/core",
  "author": "Forma <victor@getforma.dev>",
  "version": "1.0.6",
  "description": "Real DOM reactive library — fine-grained signals, islands architecture, SSR hydration. No virtual DOM, no diffing. ~15KB gzipped.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./runtime": {
      "import": {
        "types": "./dist/runtime.d.ts",
        "default": "./dist/runtime.js"
      },
      "require": {
        "types": "./dist/runtime.d.cts",
        "default": "./dist/runtime.cjs"
      }
    },
    "./runtime/global": {
      "default": "./dist/formajs-runtime.global.js"
    },
    "./runtime-hardened": {
      "import": {
        "types": "./dist/runtime-hardened.d.ts",
        "default": "./dist/runtime-hardened.js"
      },
      "require": {
        "types": "./dist/runtime-hardened.d.cts",
        "default": "./dist/runtime-hardened.cjs"
      }
    },
    "./runtime-csp": {
      "import": {
        "types": "./dist/runtime-hardened.d.ts",
        "default": "./dist/runtime-hardened.js"
      },
      "require": {
        "types": "./dist/runtime-hardened.d.cts",
        "default": "./dist/runtime-hardened.cjs"
      }
    },
    "./runtime-csp/global": {
      "default": "./dist/formajs-runtime-hardened.global.js"
    },
    "./tc39": {
      "import": {
        "types": "./dist/tc39-compat.d.ts",
        "default": "./dist/tc39-compat.js"
      },
      "require": {
        "types": "./dist/tc39-compat.d.cts",
        "default": "./dist/tc39-compat.cjs"
      }
    },
    "./ssr": {
      "import": {
        "types": "./dist/ssr/index.d.ts",
        "default": "./dist/ssr/index.js"
      },
      "require": {
        "types": "./dist/ssr/index.d.cts",
        "default": "./dist/ssr/index.cjs"
      }
    },
    "./http": {
      "import": {
        "types": "./dist/http.d.ts",
        "default": "./dist/http.js"
      },
      "require": {
        "types": "./dist/http.d.cts",
        "default": "./dist/http.cjs"
      }
    },
    "./storage": {
      "import": {
        "types": "./dist/storage.d.ts",
        "default": "./dist/storage.js"
      },
      "require": {
        "types": "./dist/storage.d.cts",
        "default": "./dist/storage.cjs"
      }
    },
    "./server": {
      "import": {
        "types": "./dist/server.d.ts",
        "default": "./dist/server.js"
      },
      "require": {
        "types": "./dist/server.d.cts",
        "default": "./dist/server.cjs"
      }
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "sideEffects": [
    "./dist/runtime.js",
    "./dist/runtime.cjs",
    "./dist/runtime-hardened.js",
    "./dist/runtime-hardened.cjs",
    "./dist/formajs-runtime.global.js",
    "./dist/formajs-runtime-hardened.global.js",
    "./dist/forma-runtime.js",
    "./dist/forma-runtime-csp.js"
  ],
  "scripts": {
    "build": "tsup && node scripts/post-build.mjs",
    "pack:release": "npm run build && npm pack --pack-destination releases",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npm run build && cp dist/formajs-runtime.global.js e2e/fixtures/ && npx playwright test",
    "docs": "typedoc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "signals",
    "reactive",
    "framework",
    "dom",
    "fine-grained",
    "real-dom",
    "no-vdom",
    "no-virtual-dom",
    "tc39-signals",
    "alien-signals",
    "lightweight",
    "typescript",
    "jsx",
    "hyperscript",
    "state-management",
    "islands",
    "islands-architecture",
    "hydration",
    "ssr",
    "server-side-rendering",
    "csp",
    "csp-safe",
    "content-security-policy",
    "declarative",
    "data-attributes",
    "alpine-alternative",
    "solidjs-alternative",
    "rust-ssr",
    "web-components",
    "progressive-enhancement",
    "zero-build",
    "cdn"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/getforma-dev/formajs.git"
  },
  "homepage": "https://getforma.dev",
  "bugs": {
    "url": "https://github.com/getforma-dev/formajs/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "alien-signals": "~3.1.2"
  },
  "overrides": {
    "rollup": "^4.59.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vitest/coverage-v8": "^4.0.18",
    "fake-indexeddb": "^6.2.3",
    "happy-dom": "^20.8.3",
    "serve": "^14.2.6",
    "tsup": "^8.5.1",
    "typedoc": "^0.28.17",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  }
}
